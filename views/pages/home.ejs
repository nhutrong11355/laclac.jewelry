    <div class="text-center mb-5">
      <span class="section-label">Bộ Sưu Tập</span>
      <h2 class="section-title">Khám Phá Sản Phẩm</h2>
      <p class="section-desc">Mỗi sản phẩm được chế tác tỉ mỉ với tình yêu. Xem qua bộ sưu tập hoặc liên hệ để thiết kế riêng.</p>
    </div>

    <!-- Filter: Dropdown for Mobile, Button Group for Desktop -->
    <!-- Remove data-aos to avoid stacking context issues with dropdown -->
    <div>
      <!-- Mobile Dropdown (hidden on desktop) -->
      <div class="d-md-none px-3 mb-4">
        <div class="dropdown w-100">
          <button class="btn btn-filter-dropdown w-100 d-flex justify-content-between align-items-center" type="button" id="dropdownFilterButton" data-bs-toggle="dropdown" aria-expanded="false">
            <span id="selectedFilterText">Tất Cả Sản Phẩm</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 8L2 4h8z" fill="currentColor"/>
            </svg>
          </button>
          <ul class="dropdown-menu dropdown-menu-filter w-100" aria-labelledby="dropdownFilterButton">
            <li><a class="dropdown-item filter-dropdown-item active" href="#" data-filter="all">Tất Cả Sản Phẩm</a></li>
            ${['Nhẫn', 'Dây chuyền', 'Bông tai', 'Vòng tay']
              .filter(c => collections.includes(c))
              .map(c => '<li><a class="dropdown-item filter-dropdown-item" href="#" data-filter="' + c + '">' + c + '</a></li>')
              .join('\n            ')}
          </ul>
        </div>
      </div>

      <!-- Desktop Button Group (hidden on mobile) -->
      <div class="d-none d-md-flex justify-content-center mb-5">
        <div class="btn-group btn-group-filter flex-wrap" role="group" aria-label="Bộ lọc sản phẩm">
          <input type="radio" class="btn-check" name="productFilter" id="filter-all" value="all" autocomplete="off" checked>
          <label class="btn btn-outline-dark rounded-pill-start filter-btn" for="filter-all" data-filter="all">Tất Cả</label>
          
          ${['Nhẫn', 'Dây chuyền', 'Bông tai', 'Vòng tay']
            .filter(c => collections.includes(c))
            .map((c, idx, arr) => {
              const normalized = c.toLowerCase().replace(/\s+/g, '-');
              const roundedClass = idx === arr.length - 1 ? 'rounded-pill-end' : '';
              return '<input type="radio" class="btn-check" name="productFilter" id="filter-' + normalized + '" value="' + c + '" autocomplete="off">' +
                     '<label class="btn btn-outline-dark ' + roundedClass + ' filter-btn" for="filter-' + normalized + '" data-filter="' + c + '">' + c + '</label>';
            }).join('\n          ')}
        </div>
      </div>
    </div>

    <!-- Products Grid -->
    <div class="row g-3 g-md-4" id="productsGrid" data-aos="fade-up" data-aos-delay="200">
      ${products.map(p => `
        <div class="col-6 col-md-6 col-lg-4 product-item" data-collection="${p.collection}">
          <a href="/product/${p.slug}" class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden text-decoration-none text-dark">
            <div class="ratio ratio-1x1 position-relative bg-white">
              ${p.images && p.images[0] && !p.images[0].startsWith('/images/') ? `
                <img src="${p.images[0]}" alt="${p.name}" class="position-absolute top-0 start-0 w-100 h-100" style="object-fit: cover;">
              ` : `
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column align-items-center justify-content-center bg-body-tertiary">
                  <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="100" height="100" fill="#F5E6E0"/>
                    <path d="M50 25L58 42H42L50 25Z" stroke="#D4A843" stroke-width="1.5" fill="none"/>
                    <circle cx="50" cy="55" r="15" stroke="#D4A843" stroke-width="1.5" fill="none"/>
                  </svg>
                  <span class="position-absolute bottom-0 start-50 translate-middle-x mb-3 px-2 text-center fst-italic small text-secondary">${p.name}</span>
                </div>
              `}
                    <button type="button" class="product-compare-btn btn btn-light text-dark border rounded-circle shadow-sm position-absolute top-0 end-0 m-2 p-0 d-inline-flex align-items-center justify-content-center"
                      data-product-id="${p.id}"
                      data-product-slug="${p.slug}"
                      data-product-name="${p.name}"
                      data-product-image="${p.images && p.images[0] || '/images/placeholder.jpg'}"
                      aria-label="Thêm ${p.name} vào so sánh"
                      aria-pressed="false"
                      title="Thêm vào so sánh"
                      style="width: 40px; height: 40px;">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 4L5 8L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M15 4L19 8L15 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="16" r="2" fill="currentColor"/>
                </svg>
              </button>
            </div>
            <div class="card-body p-3 p-md-4 d-flex flex-column justify-content-between">
              <div>
                <span class="d-block mb-2 text-uppercase small fw-semibold text-secondary">${p.collection}</span>
                <h3 class="h6 mb-0 lh-sm">${p.name}</h3>
              </div>
              <p class="small text-body-secondary mb-0 mt-2">${p.material} · ${p.stone}</p>
            </div>
          </a>
        </div>
      `).join('')}
    </div>

    <div class="d-flex justify-content-center mt-5">
      <button class="btn btn-outline-dark" id="loadMoreBtn">Xem Thêm Sản Phẩm</button>
    </div>
  </div>
</section>

