<%- include('../layouts/main', { body: `

<!-- Breadcrumb -->
<section class="breadcrumb-section">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Trang Chủ</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/#collections">${product.collection}</a>
      <span class="breadcrumb-sep">›</span>
      <span>${product.name}</span>
    </nav>
  </div>
</section>

<!-- Product Detail -->
<section class="product-detail">
  <div class="container">
    <div class="product-grid">

      <!-- Product Images -->
      <div class="product-images" data-aos="fade-right">
        <div class="product-main-image">
          <div class="product-placeholder-large">
            <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="400" height="400" fill="#F5E6E0"/>
              <path d="M200 80L230 150H170L200 80Z" stroke="#C9A96E" stroke-width="2" fill="none"/>
              <circle cx="200" cy="220" r="70" stroke="#C9A96E" stroke-width="2" fill="none"/>
              <circle cx="200" cy="220" r="50" stroke="#C9A96E" stroke-width="1" fill="none" opacity="0.4"/>
              <path d="M130 220C130 181.3 161.3 150 200 150" stroke="#C9A96E" stroke-width="1.5" fill="none" opacity="0.3"/>
            </svg>
            <span class="placeholder-text-large">${product.name}</span>
          </div>
        </div>
        <div class="product-thumbnails">
          ${product.images.map((img, i) => `
            <div class="product-thumb ${i === 0 ? 'active' : ''}">
              <div class="thumb-placeholder">
                <svg viewBox="0 0 100 100" fill="none"><rect width="100" height="100" fill="#F5E6E0"/><circle cx="50" cy="50" r="20" stroke="#C9A96E" stroke-width="1" fill="none"/></svg>
              </div>
            </div>
          `).join('')}
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-info" data-aos="fade-left">
        <span class="product-collection-tag">${product.collection}</span>
        <h1 class="product-title">${product.name}</h1>
        <p class="product-material-tag">${product.material} · ${product.stone}</p>

        <div class="product-description">
          <p>${product.description}</p>
        </div>

        <div class="product-details-section">
          <h3>Chi Tiết</h3>
          <p>${product.details}</p>
        </div>

        <div class="product-specs">
          <h3>Thông Số Kỹ Thuật</h3>
          <table class="specs-table">
            ${Object.entries(product.specs).map(([key, val]) => `
              <tr><td class="spec-label">${key}</td><td class="spec-value">${val}</td></tr>
            `).join('')}
          </table>
        </div>

        <!-- Contact to Order -->
        <div class="product-cta">
          <p class="cta-text">Bạn yêu thích sản phẩm này? Liên hệ với chúng tôi để thảo luận về tùy chọn cá nhân hóa và đặt hàng.</p>
          <div class="cta-buttons">
            <a href="https://www.instagram.com/laclac.jewelry/" target="_blank" rel="noopener" class="btn btn-primary btn-order">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5"/></svg>
              Đặt Hàng — Instagram
            </a>
            <a href="https://www.facebook.com/profile.php?id=61579703409647" target="_blank" rel="noopener" class="btn btn-outline btn-order">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              Đặt Hàng — Facebook
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Related Products -->
${related.length > 0 ? `
<section class="related-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Có Thể Bạn Cũng Thích</span>
      <h2 class="section-title">Sản Phẩm Liên Quan</h2>
    </div>
    <div class="products-grid products-grid-4">
      ${related.map(p => `
        <a href="/product/${p.slug}" class="product-card" data-aos="fade-up">
          <div class="product-card-image">
            <div class="product-placeholder">
              <svg viewBox="0 0 100 100" fill="none"><rect width="100" height="100" fill="#F5E6E0"/><path d="M50 25L58 42H42L50 25Z" stroke="#C9A96E" stroke-width="1.5" fill="none"/><circle cx="50" cy="55" r="15" stroke="#C9A96E" stroke-width="1.5" fill="none"/></svg>
              <span class="placeholder-text">${p.name}</span>
            </div>
            <div class="product-card-overlay"><span>Xem Chi Tiết</span></div>
          </div>
          <div class="product-card-info">
            <span class="product-card-collection">${p.collection}</span>
            <h3 class="product-card-name">${p.name}</h3>
            <p class="product-card-material">${p.material} · ${p.stone}</p>
          </div>
        </a>
      `).join('')}
    </div>
  </div>
</section>
` : ''}

`, pageTitle: product.name }) %>
