<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %>LacLac Jewelry - Trang Sức Cao Cấp</title>
  <meta name="description" content="LacLac Jewelry - Kim cương tự nhiên, Kim cương nhân tạo, Moissanite, Vàng & Bạc theo yêu cầu. Chế tác thủ công tại Thủ Đức, TP.HCM.">
  <link rel="icon" href="/images/laclac-logo.jpg" type="image/jpeg">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#D4A843">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>
  <main>
    <%- body %>
  </main>
  <%- include('../partials/footer') %>
  <!-- Micromodal.js - Lightweight accessible modal library (3KB) -->
  <script src="https://cdn.jsdelivr.net/npm/micromodal@0.4.10/dist/micromodal.min.js"></script>
  <!-- Fuse.js - Fuzzy Search Library -->
  <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0"></script>
  <% if (typeof products !== 'undefined' && products) { %>
  <script>
    // Embed products data for search functionality
    window.LACLAC_PRODUCTS = <%- JSON.stringify(products.map(p => ({
      name: p.name,
      collection: p.collection,
      material: p.material,
      stone: p.stone,
      slug: p.slug,
      image: p.images && p.images[0] ? p.images[0] : null,
      description: p.description || ''
    }))) %>;
  </script>
  <% } %>
  <% if (typeof gemstones !== 'undefined' && gemstones) { %>
  <script>
    // Embed gemstones data for search functionality
    window.LACLAC_GEMSTONES = <%- JSON.stringify(gemstones.map(g => ({
      name: g.name,
      tagline: g.tagline,
      slug: g.slug,
      image: g.image,
      description: g.description || ''
    }))) %>;
  </script>
  <% } %>
  <script src="/js/main.js"></script>
  <script src="/js/search.js"></script>
</body>
</html>
